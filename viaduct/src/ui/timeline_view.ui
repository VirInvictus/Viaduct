<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.16"/>
  <menu id="sort_menu">
    <section>
      <attribute name="label" translatable="yes">Sort by date</attribute>
      <item>
        <attribute name="label" translatable="yes">Newest first</attribute>
        <attribute name="action">win.timeline-sort</attribute>
        <attribute name="target">newest-first</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Oldest first</attribute>
        <attribute name="action">win.timeline-sort</attribute>
        <attribute name="target">oldest-first</attribute>
      </item>
    </section>
  </menu>
  <template class="ViaductTimelineView" parent="GtkWidget">
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkHeaderBar">
            <property name="show-title-buttons">False</property>
            <child type="end">
              <object class="GtkMenuButton" id="sort_menu_btn">
                <property name="icon-name">view-sort-descending-symbolic</property>
                <property name="tooltip-text">Sort articles</property>
                <property name="menu-model">sort_menu</property>
                <accessibility>
                  <property name="label">Sort articles</property>
                </accessibility>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkSearchBar" id="search_bar">
            <property name="key-capture-widget">timeline_list_view</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="spacing">6</property>
                <property name="hexpand">True</property>
                <child>
                  <object class="GtkSearchEntry" id="search_entry">
                    <property name="placeholder-text">Search articles…</property>
                    <property name="hexpand">True</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="scope_toggle">
                    <property name="label">This feed</property>
                    <property name="tooltip-text">Restrict search to the currently-selected feed</property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkStack" id="timeline_stack">
            <property name="vexpand">True</property>
            <property name="transition-type">crossfade</property>
            <property name="transition-duration">150</property>
            <child>
              <object class="GtkStackPage">
                <property name="name">content</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <property name="propagate-natural-width">False</property>
                    <property name="hexpand">True</property>
                    <property name="child">
                      <object class="GtkListView" id="timeline_list_view">
                        <property name="hexpand">True</property>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">empty</property>
                <property name="child">
                  <object class="ViaductStatusPage" id="timeline_empty_status"/>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
