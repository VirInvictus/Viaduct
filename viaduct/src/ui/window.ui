<interface>
  <requires lib="gtk" version="4.16"/>
  <template class="ViaductWindow" parent="GtkApplicationWindow">
    <property name="title">viaduct</property>
    <property name="default-width">1200</property>
    <property name="default-height">800</property>
    <!-- Phase 20c: no separate window titlebar. An invisible one suppresses
         GTK's default titlebar; the window controls render on the sidebar
         pane's own GtkHeaderBar (show-title-buttons stays true there), the
         outermost bar, per the 20a decision. -->
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="visible">False</property>
      </object>
    </child>
    <property name="child">
      <object class="GtkOverlay" id="toast_overlay">
        <child type="overlay">
          <object class="GtkRevealer" id="toast_revealer">
            <property name="halign">center</property>
            <property name="valign">end</property>
            <property name="margin-bottom">18</property>
            <property name="can-target">False</property>
            <property name="transition-type">crossfade</property>
            <property name="reveal-child">False</property>
            <property name="child">
              <object class="GtkLabel" id="toast_label">
                <property name="wrap">True</property>
                <property name="max-width-chars">50</property>
                <style>
                  <class name="toast"/>
                </style>
              </object>
            </property>
          </object>
        </child>
        <property name="child">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <!-- Outer paned: sidebar | (timeline + article). Sidebar
                   keeps its width when the window resizes; the article pane
                   absorbs the extra space. -->
              <object class="GtkPaned" id="outer_split_view">
                <property name="vexpand">True</property>
                <property name="position">260</property>
                <property name="resize-start-child">False</property>
                <property name="shrink-start-child">False</property>
                <property name="shrink-end-child">False</property>
                <property name="start-child">
                  <object class="ViaductSidebarView" id="sidebar_view"/>
                </property>
                <property name="end-child">
                  <object class="GtkPaned" id="inner_split_view">
                    <property name="position">340</property>
                    <property name="resize-start-child">False</property>
                    <property name="shrink-start-child">False</property>
                    <property name="shrink-end-child">False</property>
                    <property name="start-child">
                      <object class="ViaductTimelineView" id="timeline_view"/>
                    </property>
                    <property name="end-child">
                      <object class="ViaductArticlePaneView" id="article_pane"/>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <!-- v2.6.10 refresh progress strip. Hidden until the next
                 refresh cycle starts; fades in via Revealer's slide-up,
                 fades out when the cycle completes. -->
            <child>
              <object class="GtkRevealer" id="refresh_progress_revealer">
                <property name="transition-type">slide-up</property>
                <property name="reveal-child">False</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">4</property>
                    <property name="margin-start">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-top">6</property>
                    <property name="margin-bottom">6</property>
                    <child>
                      <object class="GtkLabel" id="refresh_progress_label">
                        <property name="halign">start</property>
                        <property name="xalign">0</property>
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="caption"/>
                          <class name="dim-label"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkProgressBar" id="refresh_progress_bar">
                        <property name="hexpand">True</property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
