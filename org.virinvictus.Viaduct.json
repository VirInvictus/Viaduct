{
    "app-id": "org.virinvictus.Viaduct",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "viaduct",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--talk-name=org.freedesktop.secrets"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/viaduct/cargo"
        }
    },
    "modules": [
        {
            "name": "viaduct",
            "buildsystem": "simple",
            "build-commands": [
                "cargo build --release",
                "install -Dm755 target/release/viaduct /app/bin/viaduct",
                "install -Dm644 data/org.virinvictus.Viaduct.gschema.xml /app/share/glib-2.0/schemas/org.virinvictus.Viaduct.gschema.xml",
                "glib-compile-schemas /app/share/glib-2.0/schemas"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
