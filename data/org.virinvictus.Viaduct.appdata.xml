  <name>Viaduct</name>
  <summary>Fast, native RSS reader for GNOME</summary>
  <description>
    <p>
      Viaduct is a native RSS reader for GNOME, built in Rust with GTK4 and libadwaita.
      It aims for full feature parity with NetNewsWire, providing a fast and familiar experience.
    </p>
    <ul>
      <li>Local account support</li>
      <li>Inoreader sync support</li>
      <li>Adaptive UI for mobile and desktop</li>
      <li>Blazing fast FTS5 search</li>
    </ul>
  </description>
  <launchable type="desktop-id">org.virinvictus.Viaduct.desktop</launchable>
  <url type="homepage">https://github.com/virinvictus/Viaduct</url>
